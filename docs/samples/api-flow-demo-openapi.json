{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenMelon Runtime Smoke API",
    "version": "1.0.0",
    "description": "用于 API 自动化演示的 OpenMelon 当前服务只读接口资产。"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/api/ping": {
      "get": {
        "operationId": "ping",
        "summary": "服务连通性检查",
        "tags": ["runtime"],
        "responses": {
          "200": {
            "description": "服务可用",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/system/health": {
      "get": {
        "operationId": "systemHealth",
        "summary": "系统健康状态",
        "tags": ["runtime"],
        "responses": {
          "200": {
            "description": "系统健康状态",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "version": { "type": "string" },
                    "checked_at": { "type": "string" },
                    "components": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/metrics": {
      "get": {
        "operationId": "metrics",
        "summary": "运行指标快照",
        "tags": ["runtime"],
        "responses": {
          "200": {
            "description": "运行指标",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    }
  }
}
