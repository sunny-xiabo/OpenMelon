# AI 模型 API 配置（统一 API 网关，如 one-api）
# 复制此文件为 .env 并填入你的实际配置

# 统一 API Key（Qwen、DeepSeek 等均使用此 key，除非下面单独指定）
OPEN_API_KEY=your_api_key

# 统一 Base URL（可选，默认 https://one-api.miotech.com/v1）
# OPEN_API_BASE_URL=https://one-api.miotech.com/v1

# 模型名称（可选，用于多模态/文本模型，未设置则使用下方默认值）
# 多模态模型（图像等），默认 qwen3-vl-32b-siliconflow
# QWEN_MODEL_NAME=qwen3-vl-32b-siliconflow
# 文本模型（PDF/OpenAPI/文本等），默认 deepseek-v3.2
# DEEPSEEK_MODEL_NAME=deepseek-v3.2

# 以下为可选：仅当需要为某模型使用不同 key 时配置
# QWEN_API_KEY=your_api_key
# DEEPSEEK_API_KEY=your_api_key
