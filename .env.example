# ============================================================
# OpenMelon 环境配置详解
# ============================================================
#
# 本文件为配置模板，复制为 .env 后修改实际值
# 路径: cp .env.example .env
#
# 优先级说明:
# - testcase_gen 优先使用 CUSTOM > QWEN_API_KEY > DEEPSEEK_API_KEY > 统一 API_KEY
# - OpenMelon 主模块使用 LLM_PROVIDER 指定的 Provider 配置
# ============================================================

# ============================================================
# 0. 运行时数据目录与本地网络（可选）
# ============================================================

# OpenMelon 运行时数据目录
# 默认: backend/runtime
# 会影响上传临时目录、导出结果、运行日志等运行时文件位置
# OPENMELON_DATA_DIR=backend/runtime

# 节点类型配置文件路径
# 默认: backend/config/node_types.json
# NODE_TYPES_CONFIG_PATH=backend/config/node_types.json

# 应用运行环境与调试开关
# 开发环境默认允许任意 CORS 来源；生产环境请显式配置 CORS_ALLOW_ORIGINS
# APP_ENV=development
# DEBUG=false
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://openmelon.example.com
#
# 生产访问控制，默认关闭以保持本地演示友好。
# 开启后，删除/清空/配置/执行触发等高风险接口需要 X-API-Key 或 Bearer JWT。
# PROTECT_ADMIN_API=false
# ADMIN_API_KEYS=replace-with-long-random-key
# ADMIN_JWT_SECRET=replace-with-long-random-secret

# 防止 Python httpx/requests 通过代理访问本地服务（Qdrant/Neo4j 在本地或 Docker）
# 如未设置代理此项无害；如设置了全局代理则建议启用
# NO_PROXY=localhost,127.0.0.1
# no_proxy=localhost,127.0.0.1

# ============================================================
# 1. Neo4j 数据库配置（必须）
# ============================================================
# 数据库连接地址（单机本地环境强烈建议使用 bolt://，避免路由获取失败的警告）
NEO4J_URI=bolt://localhost:7687

# 数据库用户名（Neo4j 安装时设置）
NEO4J_USER=neo4j

# 数据库密码（Neo4j 安装时设置，默认 password）
NEO4J_PASSWORD=password

# 数据库名称（可选，默认 neo4j）
NEO4J_DATABASE=neo4j

# ============================================================
# 1.5 外部向量数据库配置（可选）
# 用于分离向量存储到专业的向量数据库中（如 Qdrant）
# 默认配置下所有切片及向量全量存在 Neo4j
# ============================================================

# 是否启用外部向量库 (开启后开启双写与外部检索优先)
# 默认: false
# USE_EXTERNAL_VECTOR=false

# 向量库提供商
# VECTOR_PROVIDER=qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# Qdrant 开启鉴权时使用（可选）
# QDRANT_API_KEY=
# 新建/显式重建 Qdrant collection 时启用 scalar int8 量化，降低向量检索内存与延迟
# QDRANT_ENABLE_QUANTIZATION=true
# QDRANT_QUANTIZATION_TYPE=scalar_int8
# QDRANT_FORCE_RECREATE_ON_QUANTIZATION=true

# 外部库检索报错时，是否平滑降级回 Neo4j 查询
# 默认: true
# VECTOR_FALLBACK_TO_NEO4J=true
# Neo4j 批量写入分批大小
# NEO4J_WRITE_BATCH_SIZE=500

# ============================================================
# 1.6 PostgreSQL 运行时配置
# ============================================================
# OpenMelon 结构化运行时数据只使用 PostgreSQL。
# DATABASE_URL 为必填项；缺失时后端启动失败。
# 当前 PG runtime 覆盖 API execution、FileTracker、Prompt Hub、NodeTypeStore、日志中心和 AI 调用观测。
#
# Docker 一键启动会自动注入容器内 DATABASE_URL；本机运行后端时请使用 localhost 连接串。
#   docker compose up -d postgres neo4j qdrant
#   DATABASE_URL=postgresql://openmelon:openmelon@localhost:5432/openmelon
# POSTGRES_DB=openmelon
# POSTGRES_USER=openmelon
# POSTGRES_PASSWORD=openmelon
# POSTGRES_PORT=5432
# POSTGRES_HEALTHCHECK_ENABLED=false
# POSTGRES_HOST=localhost
# DATABASE_URL=postgresql://openmelon:openmelon@localhost:5432/openmelon

# ============================================================
# 1.7 API 自动化执行队列
# ============================================================
# 单节点执行队列配置；不引入外部队列时用于控制后台 API 执行吞吐和 SSE 缓冲。
# API_EXECUTION_MAX_CONCURRENT_RUNS=2
# API_EXECUTION_QUEUE_WAIT_TIMEOUT_S=60
# API_EXECUTION_SSE_QUEUE_SIZE=100

# ============================================================
# 2. OpenMelon 主模块 LLM 配置（必须）
# 用于: 向量Embedding、实体提取、智能问答
# ============================================================

# LLM Provider 选择
# 可选值: openai_compat | openai | qwen | deepseek | mimo
# - openai_compat: 使用公司统一中转网关（OpenAI-compatible，默认配置）
# - openai: OpenAI 官方直连
# - qwen: 阿里通义千问
# - deepseek: DeepSeek 官方
# - mimo: Mimo 官方
LLM_PROVIDER=openai_compat

# --- 常用模板（复制一组即可） ---
# 模板 A：公司统一中转（推荐）
# LLM_PROVIDER=openai_compat
# API_BASE_URL=https://one-api.miotech.com/v1
# CHAT_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIM=1024
#
# 模板 B：OpenAI 官方直连
# LLM_PROVIDER=openai
# API_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1024
# 说明：text-embedding-3 系列支持 dimensions 参数，项目会按 EMBEDDING_DIM 统一输出维度

# API Key（必填，从对应 Provider 获取）
API_KEY=sk-your-key-here

# API Base URL（可选，留空则使用 Provider 默认地址）
# 例如: https://one-api.miotech.com/v1
#       https://dashscope.aliyuncs.com/compatible-mode/v1
#       https://api.deepseek.com/v1
API_BASE_URL=

# Chat 模型名称（可选，不填则使用 Provider 默认值）
# openai_compat 默认: qwen-plus
# openai 默认: gpt-4o-mini
# qwen 默认: qwen-plus
# deepseek 默认: deepseek-chat
# mimo 默认: mimo-v2-flash
CHAT_MODEL=

# Embedding 模型名称（用于文档向量化）
# qwen 推荐: text-embedding-v3
# openai_compat 推荐: text-embedding-v3
# openai 推荐: text-embedding-3-small
EMBEDDING_MODEL=

# Embedding 向量维度（必须与模型匹配）
# text-embedding-v3: 1024
# text-embedding-3-small: 默认 1536（本项目可通过 dimensions 参数统一为 1024）
EMBEDDING_DIM=


# ============================================================
# 3. 检索配置（可选）
# ============================================================

# 向量检索返回的 Top K 条数
# 默认: 5
# RETRIEVAL_TOP_K=5
# RAG 混合检索单路 graph/vector 超时，单路失败不阻塞整体回答
# RAG_RETRIEVAL_CHANNEL_TIMEOUT_S=5.0

# RAG 热点查询缓存开关与 TTL/容量
# 默认: enabled=true, retrieval_ttl=300, answer_ttl=120
# RAG_CACHE_ENABLED=true
# RAG_RETRIEVAL_CACHE_TTL_S=300
# RAG_ANSWER_CACHE_TTL_S=120
# RAG_RETRIEVAL_CACHE_MAX_ENTRIES=256
# RAG_ANSWER_CACHE_MAX_ENTRIES=128

# 知识图谱检索深度（递归查询层数）
# 默认: 2
# RETRIEVAL_DEPTH=2

# Reranker 重排后返回的 Top K
# 默认: 5
# RERANKER_TOP_K=5

# Reranker 相似度阈值（低于此分数的结果被过滤）
# 默认: 0.3
# RERANKER_SCORE_THRESHOLD=0.3


# ============================================================
# 4. 混合检索权重（可选）
# 用于同时使用图谱+向量检索时的结果融合
# ============================================================

# 知识图谱检索结果的权重
# 默认: 0.4 (40%)
# HYBRID_GRAPH_WEIGHT=0.4

# 向量检索结果的权重
# 默认: 0.6 (60%)
# HYBRID_VECTOR_WEIGHT=0.6


# ============================================================
# 5. LLM 生成配置（可选）
# ============================================================

# 生成回答的温度参数（0-1，越高越有创造性）
# 默认: 0.3
# GENERATION_TEMPERATURE=0.3

# 生成回答的最大 token 数
# 默认: 2000
# GENERATION_MAX_TOKENS=2000


# ============================================================
# 5.5 文件上传与日志生命周期（可选）
# ============================================================

# 测试用例生成允许上传的单文件大小，单位 MB
# 默认: 10
# MAX_FILE_SIZE_MB=10

# 事件日志自动裁剪保留天数
# 默认: 90
# EVENT_LOG_RETENTION_DAYS=90

# 事件日志最大保留行数，超过后会优先裁剪较旧的非 Error 日志
# 默认: 50000
# EVENT_LOG_MAX_ROWS=50000


# ============================================================
# 6. Agentic RAG 多步推理配置（可选）
# 启用后，系统会自动改写查询、评估答案充分性、迭代检索
# ============================================================

# 最大迭代次数（超过则返回当前最佳答案）
# 默认: 3
# AGENTIC_MAX_STEPS=3

# 答案充分性置信度阈值（高于此值则认为答案足够）
# 默认: 0.7
# AGENTIC_CONFIDENCE_THRESHOLD=0.7


# ============================================================
# 7. 意图分类配置（可选）
# 用于判断用户问题是: 图谱查询 / 向量查询 / 混合查询 / 可视化
# ============================================================

# 意图分类置信度阈值（低于此值则使用默认意图）
# 默认: 0.5
# INTENT_CONFIDENCE_THRESHOLD=0.5


# ============================================================
# 8. BGE Reranker 重排序配置（可选）
# 在向量检索后使用 BGE Reranker 重新排序，提升相关性
# 需要安装: pip install FlagEmbedding
# ============================================================

# 是否启用 Reranker
# 默认: true（如果设为 false，以下配置无效）
# USE_RERANKER=true

# Reranker 运行模式
# 可选: sidecar | local | disabled
# - sidecar: 主后端通过独立 reranker 服务调用，推荐 Docker 部署
# - local: 主后端进程内加载模型，需执行 uv sync --extra reranker
# - disabled: 关闭重排
# 默认: local（Docker Compose 中 app 默认覆盖为 sidecar）
# RERANKER_BACKEND=local

# Sidecar 服务地址，仅 RERANKER_BACKEND=sidecar 时使用
# Docker Compose 内部默认: http://reranker:8010
# 本机 sidecar 默认: http://localhost:8010
# RERANKER_URL=http://localhost:8010

# Sidecar 请求超时时间，单位秒
# 默认: 5
# RERANKER_TIMEOUT_SECONDS=5

# Reranker 模型名称
# 推荐: BAAI/bge-reranker-v2-m3（支持中英文）
# 其他: BAAI/bge-reranker-base
# RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# 运行设备
# 可选: cpu | cuda（需要 GPU）
# 默认: cpu
# RERANKER_DEVICE=cpu


# ============================================================
# 9. 企业 Webhook 配置（可选）
# 问答结果可推送到钉钉/飞书/企业微信群
# ============================================================

# --- 钉钉 ---
# Webhook 地址（获取方式: 钉钉群设置 -> 智能群助手 -> 添加机器人）
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 加签密钥（机器人设置中开启"加签"后获取）
# DINGTALK_SECRET=your-secret

# --- 飞书 ---
# Webhook 地址（获取方式: 飞书群设置 -> 群机器人 -> 添加机器人 -> 自定义机器人）
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# --- 企业微信 ---
# Webhook 地址（获取方式: 企业微信群 -> 添加群机器人 -> 创建机器人）
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ============================================================
# 9.1 消息接收配置（可选）
# 配置后可在对应平台直接对话问答
# ============================================================

# --- 钉钉消息接收 ---
# 获取方式: 钉钉群 -> 智能群助手 -> 添加机器人 -> 自定义机器人
# 注意: 需要开启"加签"才能接收消息
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# DINGTALK_SECRET=your-secret

# --- 飞书消息接收 ---
# 获取方式: 飞书群 -> 群设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
# 需要在机器人设置中开启"验证签名"并获取 Verification Token
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# FEISHU_VERIFICATION_TOKEN=your-verification-token

# --- 企业微信消息接收 ---
# 需要后台权限，详见 9.2
# WECOM_TOKEN=your-token
# WECOM_ENCODING_AES_KEY=your-encoding-aes-key
# WECOM_CORP_ID=your-corp-id
# WECOM_AGENT_ID=your-agent-id


# ============================================================
# 10. testcase_gen 独立 LLM 配置（可选）
# 测试用例生成模块可使用独立于主模块的 LLM
# 优先级: CUSTOM > QWEN_API_KEY > DEEPSEEK_API_KEY > 统一 API_KEY
# ============================================================

# --- 自定义模型（最高优先级）---
# 同时用于视觉理解（图像分析）和文本生成（用例编写）
# CUSTOM_API_KEY=sk-your-key
# CUSTOM_BASE_URL=https://api.siliconflow.cn/v1
# CUSTOM_MODEL_NAME=deepseek-ai/DeepSeek-V3

# --- Qwen 视觉模型（优先级次之）---
# 用于测试用例生成中的图像分析（如需求文档截图）
# QWEN_API_KEY=sk-your-qwen-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 推荐模型: qwen-vl-max（最强视觉能力）
#          qwen2.5-vl-72b-instruct
#          qwen2.5-vl-32b-instruct
# QWEN_MODEL_NAME=qwen-vl-max

# --- DeepSeek 文本模型（优先级第三）---
# 用于测试用例生成的文本生成（用例编写、评审）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 推荐模型: deepseek-chat（通用对话）
#          deepseek-coder（代码能力更强）
# DEEPSEEK_MODEL_NAME=deepseek-chat


# ============================================================
# 11. testcase_gen 请求限流配置（可选）
# 防止 API 调用过于频繁被限流
# ============================================================

# 每分钟最大请求数
# 默认: 60
# RATE_LIMIT_RPM=60

# 每小时最大请求数（testcase_gen 内部限流使用）
# 默认: 100
# RATE_LIMIT_RPH=100

# 是否启用限流
# 默认: true
# RATE_LIMIT_ENABLED=true

# 突发请求最大数量
# 默认: 10
# RATE_LIMIT_BURST=10


# ============================================================
# 12. testcase_gen 认证配置（可选）
# 仅在你希望开启 API 鉴权时配置
# ============================================================

# JWT 签名密钥（建议使用高强度随机字符串）
# 默认: 自动生成（服务重启会变化）
# JWT_SECRET_KEY=replace-with-a-secure-random-string

# JWT 过期时间（小时）
# 默认: 24
# JWT_EXPIRATION_HOURS=24

# 有效 API Keys（逗号分隔，格式: key:name）
# 示例: tcg_xxx:dev-user,tcg_yyy:qa-user
# 为空时表示开发模式（不强制鉴权）
# VALID_API_KEYS=


# ============================================================
# Provider 对照表
# ============================================================
#
#
# | Provider | base_url 常用值                      | 常用模型                          |
# |----------|--------------------------------------|----------------------------------|
# | openai_compat | https://one-api.miotech.com/v1 | qwen-plus, text-embedding-v3    |
# | openai   | https://api.openai.com/v1          | gpt-4o-mini, text-embedding-3-small |
# | qwen     | https://dashscope.aliyuncs.com/...  | qwen-plus, qwen-vl-max          |
# | deepseek | https://api.deepseek.com/v1         | deepseek-chat, deepseek-coder   |
# | mimo     | https://open.mimo.work/v1           | mimo-v2-flash                   |
#
# Embedding 模型维度:
# | 模型                         | 维度 |
# |-----------------------------|------|
# | text-embedding-v3          | 1024 |
# | text-embedding-3-small     | 默认1536（本项目可统一为1024） |
# | BAAI/bge-large-zh-v1.5    | 1024 |
# | BAAI/bge-base-zh-v1.5     | 768  |
# ============================================================
